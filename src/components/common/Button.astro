---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  class?: string;
  ariaLabel?: string;
}

const { href, variant = "primary", class: className = "", ariaLabel, ...attrs } = Astro.props;
const classes = ["button", `button--${variant}`, className];
---

{
  href ? (
    <a href={href} class:list={classes} aria-label={ariaLabel} {...attrs}>
      <slot />
    </a>
  ) : (
    <button class:list={classes} aria-label={ariaLabel} {...attrs}>
      <slot />
    </button>
  )
}
