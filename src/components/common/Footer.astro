---
import { footerGroups } from "../../data/navigation";
import { site } from "../../data/site";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__brand">
      <img src="/images/logo-tm.png" alt={site.name} />
      <p>
        Sicurezza urbana collaborativa per persone, citta e partner locali.
      </p>
      <a href={`mailto:${site.emails.contact}`}>{site.emails.contact}</a>
      <address class="site-footer__company">
        <strong>{site.company.legalName}</strong>
        <span>{site.company.street}</span>
        <span>{site.company.postalCode} {site.company.city}</span>
        <span>{site.company.country}</span>
        <a href={`tel:${site.company.phoneHref}`}>{site.company.phone}</a>
      </address>
    </div>

    {footerGroups.map((group) => (
      <nav class="footer-group" aria-label={group.title}>
        <h2>{group.title}</h2>
        {group.links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </nav>
    ))}
  </div>

  <div class="container site-footer__bottom">
    <p>© {year} {site.company.legalName}. Tutti i diritti riservati.</p>
    <p>Part. IVA: {site.company.vat} - REA: {site.company.rea}</p>
    <button class="site-footer__cookie-link" type="button" data-cookie-preferences>
      Rivedi le tue scelte sui cookie
    </button>
  </div>
</footer>
