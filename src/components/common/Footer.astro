---
import { footerGroups } from "../../data/navigation";
import { site } from "../../data/site";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__brand">
      <img src="/images/logo-tm.png" alt={site.name} />
      <p>
        Sicurezza urbana collaborativa per persone, citta e partner locali.
      </p>
      <a href={`mailto:${site.emails.general}`}>{site.emails.general}</a>
    </div>

    {footerGroups.map((group) => (
      <nav class="footer-group" aria-label={group.title}>
        <h2>{group.title}</h2>
        {group.links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </nav>
    ))}
  </div>

  <div class="container site-footer__bottom">
    <p>© {year} {site.company.legalName}. Tutti i diritti riservati.</p>
    <p>{site.company.city}, {site.company.country}</p>
  </div>
</footer>
