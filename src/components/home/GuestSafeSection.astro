---
import Button from "../common/Button.astro";
---

<section class="section section--dark">
  <div class="container two-column two-column--center">
    <div>
      <p class="eyebrow">GuestSafe</p>
      <h2>Una linea dedicata per hotel, residence e strutture ricettive.</h2>
    </div>
    <div class="text-stack">
      <p>
        GuestSafe aiuta le strutture a offrire agli ospiti indicazioni localizzate, strumenti digitali e comunicazioni piu chiare su sicurezza, quartieri, spostamenti e assistenza.
      </p>
      <Button href="/guestsafe">Scopri GuestSafe</Button>
    </div>
  </div>
</section>
