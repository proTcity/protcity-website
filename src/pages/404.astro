---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Pagina non trovata"
  description="La pagina richiesta non esiste o è stata spostata."
  canonicalPath="/404"
  robots="noindex, follow"
  bodyClass="cinematic-site"
>
  <section class="cinematic-hero feature-hero feature-hero--app">
    <div class="cinematic-hero__overlay"></div>
    <div class="container cinematic-hero__content">
      <p class="eyebrow">Errore 404</p>
      <h1>Questa pagina non è più sulla mappa.</h1>
      <p>
        Il link potrebbe essere cambiato o il contenuto potrebbe non essere ancora stato pubblicato.
      </p>
      <div class="cinematic-hero__actions">
        <a class="glass-button glass-button--primary" href="/">Torna alla homepage</a>
        <a class="glass-button" href="/contact">Contatti</a>
      </div>
    </div>
  </section>
</MainLayout>
