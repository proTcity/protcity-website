---
import MainLayout from "../layouts/MainLayout.astro";
import { site } from "../data/site";
import { getSeoResourcePath, seoHubPages, seoHubPath } from "../data/seoHub";
import { absoluteUrl } from "../utils/seo";

const title = "Sicurezza urbana intelligente";
const description =
  "Hub proTcity sulla sicurezza urbana intelligente: app sicurezza personale, percorsi sicuri, segnalazioni cittadini, Comuni, hotel, turisti e AI responsabile.";

const hubPreviewImages = [
  "/images/app-real/optimized/walkguard6.png",
  "/images/app-real/optimized/sos.png",
  "/images/app-real/optimized/walkguard5.png",
  "/images/app-real/optimized/segnalazione.png"
];

const hubCards = seoHubPages.map((page, index) => ({
  ...page,
  displayImage: hubPreviewImages[index] ?? page.image
}));

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: `${title} | ${site.name}`,
    description,
    url: absoluteUrl(seoHubPath),
    inLanguage: "it-IT",
    isPartOf: {
      "@type": "WebSite",
      name: site.name,
      url: absoluteUrl("/")
    },
    publisher: {
      "@type": "Organization",
      name: site.company.legalName,
      url: absoluteUrl("/")
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "proTcity",
        item: absoluteUrl("/")
      },
      {
        "@type": "ListItem",
        position: 2,
        name: title,
        item: absoluteUrl(seoHubPath)
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Risorse proTcity sulla sicurezza urbana intelligente",
    itemListElement: seoHubPages.map((page, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: page.title,
      url: absoluteUrl(getSeoResourcePath(page.slug))
    }))
  }
];
---

<MainLayout
  title={title}
  description={description}
  canonicalPath={seoHubPath}
  bodyClass="cinematic-site"
  schema={schema}
>
  <section class="cinematic-hero feature-hero feature-hero--urban-safety">
    <div class="cinematic-hero__media"></div>
    <div class="cinematic-hero__shade"></div>
    <div class="container cinematic-hero__content">
      <p class="eyebrow">Hub proTcity</p>
      <h1>Sicurezza urbana intelligente, spiegata in modo semplice e utile.</h1>
      <p class="cinematic-hero__lead">
        Una raccolta di risorse per chi cerca app di sicurezza personale, percorsi piu prudenti, segnalazioni cittadini, strumenti per Comuni, hotel, turisti e AI responsabile.
      </p>
      <div class="cinematic-hero__actions">
        <a class="glass-button glass-button--primary" href="/app">Scopri l'app</a>
        <a class="glass-button" href="/technology">Tecnologia e AI</a>
        <a class="glass-button" href="/partner">Partner ed enti</a>
      </div>
    </div>
  </section>

  <section class="signal-strip signal-strip--floating" aria-label="Temi principali">
    <div class="container">
      <div class="signal-strip__grid">
        <article>
          <span>01</span>
          <h3>Persone</h3>
          <p>Orientamento, rientri, contatti fidati, SOS, WalkGuard e supporto AI nei momenti in cui serve chiarezza.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Territori</h3>
          <p>Segnalazioni, stati, timeline e dati aggregati per aiutare Comuni ed enti a leggere meglio il contesto urbano.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Ospitalita</h3>
          <p>GuestSafe, percorsi prudenti e punti utili per hotel, strutture ricettive e ospiti che visitano una citta nuova.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="cinematic-section" aria-labelledby="hub-topics-title">
    <div class="container section-intro section-intro--center">
      <p class="cinematic-kicker">Risorse SEO</p>
      <h2 id="hub-topics-title">Pagine pensate per rispondere alle ricerche reali sulla sicurezza.</h2>
      <p>
        Ogni pagina approfondisce una domanda concreta: come muoversi meglio, come segnalare, come aiutare turisti e ospiti, come usare AI e dati senza creare panico.
      </p>
    </div>

    <div class="container seo-topic-grid">
      {hubCards.map((page) => (
        <a class="seo-topic-card" href={getSeoResourcePath(page.slug)}>
          <img src={page.displayImage} alt="" loading="lazy" decoding="async" />
          <div>
            <span>{page.eyebrow}</span>
            <h3>{page.title}</h3>
            <p>{page.intent}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="cinematic-band" aria-labelledby="method-title">
    <div class="container feature-split glass-panel">
      <figure class="image-frame image-frame--wide">
        <img
          src="/images/features/optimized/city-pulse.webp"
          alt="proTcity unisce mappa, alert, percorsi e AI per sicurezza urbana intelligente"
          loading="lazy"
          decoding="async"
        />
      </figure>
      <div class="feature-split__copy">
        <p class="eyebrow">Metodo proTcity</p>
        <h2 id="method-title">Non keyword riempite a forza. Contenuti utili, collegati e verificabili.</h2>
        <p>
          L'obiettivo dell'hub e' far capire a Google e alle persone di cosa parla proTcity: sicurezza urbana collaborativa, app mobile, WalkGuard, segnalazioni, Comuni, hotel e AI con limiti chiari.
        </p>
        <ul class="glass-list">
          <li>Una pagina principale per il tema generale.</li>
          <li>Pagine cluster per ricerche specifiche e realistiche.</li>
          <li>Link interni, sitemap e dati strutturati coerenti.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="cinematic-final" aria-labelledby="seo-final-title">
    <div class="cinematic-final__media" aria-hidden="true"></div>
    <div class="container cinematic-final__content">
      <p class="cinematic-kicker">proTcity</p>
      <h2 id="seo-final-title">La sicurezza urbana diventa piu leggibile quando le informazioni sono ordinate.</h2>
      <p>
        Dalla persona che rientra a casa al Comune che riceve segnalazioni, proTcity nasce per trasformare segnali sparsi in supporto concreto, senza sostituire autorita o canali ufficiali.
      </p>
      <div class="cinematic-actions">
        <a class="glass-button glass-button--primary" href="/contact">Parla con noi</a>
        <a class="glass-button" href="/risorse/sicurezza-urbana">Leggi la guida</a>
      </div>
    </div>
  </section>
</MainLayout>
