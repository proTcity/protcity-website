---
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/common/Button.astro";
import { site } from "../data/site";

const businessPlans = [
  {
    name: "Business Basic",
    subtitle: "Per piccole attività locali",
    price: "In arrivo",
    period: "accesso anticipato",
    cta: "Richiedi informazioni",
    subject: "Richiesta informazioni Business Basic",
    features: [
      "Profilo attività su proTcity",
      "Safe Point base sulla mappa",
      "Statistiche essenziali di zona",
      "1 sede principale",
      "Accesso Partner Console"
    ]
  },
  {
    name: "Business Professional",
    subtitle: "Per attività che vogliono visibilità e dati",
    price: "In arrivo",
    period: "accesso anticipato",
    cta: "Richiedi informazioni",
    subject: "Richiesta informazioni Business Professional",
    highlighted: true,
    features: [
      "Tutto il piano Basic",
      "Profilo avanzato e priorità Safe Point",
      "Insight territoriali più completi",
      "Più utenti autorizzati in console",
      "Pubblicazioni e contenuti estesi"
    ]
  },
  {
    name: "Business Enterprise",
    subtitle: "Piano full per aziende strutturate",
    price: "Su richiesta",
    period: "pre-lancio",
    cta: "Richiedi informazioni",
    subject: "Richiesta informazioni Business Enterprise",
    features: [
      "Tutto il piano Professional",
      "Multi-sede e gestione avanzata",
      "Limiti operativi estesi",
      "Statistiche complete",
      "Supporto prioritario"
    ]
  }
];

const publicSectorPlans = [
  {
    name: "Comune Start",
    description: "Dashboard segnalazioni, stati operativi, mappa territoriale e filtri base."
  },
  {
    name: "Comune Pro",
    description: "Timeline interventi, operatori multipli, analytics territoriali e priorità segnalazioni."
  },
  {
    name: "Ente Enterprise",
    description: "Multi-area, ruoli avanzati, integrazioni, reportistica e supporto dedicato."
  }
];

function mailtoPlan(subject: string) {
  const body = [
    "Buongiorno proTcity,",
    "",
    `vorrei ricevere informazioni sul piano: ${subject
      .replace("Richiesta informazioni ", "")
      .replace("Richiesta preventivo ", "")}.`,
    "",
    "Dati da completare:",
    "- Ragione sociale:",
    "- Partita IVA:",
    "- Città:",
    "- Referente:",
    "- Telefono:",
    "",
    "Grazie."
  ].join("\n");

  return `mailto:${site.emails.business}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
}
---

<MainLayout
  title="Diventa Partner"
  description="Piani e richiesta accesso per aziende, attività commerciali, hotel ed enti pubblici che vogliono entrare nella rete proTcity."
  canonicalPath="/partner"
  bodyClass="cinematic-site"
>
  <section class="cinematic-hero feature-hero feature-hero--partner">
    <div class="cinematic-hero__media"></div>
    <div class="cinematic-hero__shade"></div>
    <div class="container cinematic-hero__content">
      <p class="eyebrow">Diventa Partner</p>
      <h1>Una console per aziende, hotel ed enti che vogliono lavorare con il territorio.</h1>
      <p class="cinematic-hero__lead">
        Aziende, hotel, attività locali ed enti pubblici possono usare proTcity per diventare punti
        riconoscibili, leggere meglio il territorio e gestire servizi dedicati da una console sicura.
      </p>
      <div class="cinematic-hero__actions">
        <a class="glass-button glass-button--primary" href="#aziende">Piani aziende</a>
        <a class="glass-button" href="#enti">Soluzioni Enti</a>
      </div>
    </div>
  </section>

  <section class="cinematic-section partner-visual-section">
    <div class="container">
      <div class="partner-section-heading">
        <p class="eyebrow">Come si attiva il valore</p>
        <h2>Cinque settori, una sola logica: comunicare e intervenire nel momento giusto.</h2>
        <p>
          proTcity separa le esperienze operative per attività locali, strutture ricettive,
          Comuni, uffici tecnici e soggetti di sicurezza territoriale. Ogni console mantiene
          ruoli, contenuti e finalità distinti, ma lavora sulla stessa idea: informazioni
          geolocalizzate, più pertinenti e più facili da trasformare in azioni.
        </p>
      </div>

      <div class="partner-visual-grid">
        <article class="partner-visual-card">
          <figure class="partner-visual-card__media">
            <img
              src="/images/partner/reel-partners-business.webp"
              alt="proTcity per attività commerciali con console, notifiche locali e dati di afflusso"
              loading="lazy"
            />
          </figure>
          <div class="partner-visual-card__copy">
            <span>Attività commerciali</span>
            <h3>Promozioni locali più mirate, senza disperdere budget.</h3>
            <p>
              La console Partner aiuta negozi, ristoranti, strutture ricettive e attività locali
              a comunicare con persone realmente vicine, scegliere un raggio operativo, programmare
              offerte o contenuti utili e leggere dati essenziali sull'interesse generato.
            </p>
            <p>
              L'obiettivo è trasformare la visibilità in azioni misurabili: meno comunicazione
              generica, più contesto territoriale, messaggi pertinenti e una presenza riconoscibile
              dentro l'ecosistema proTcity.
            </p>
          </div>
        </article>

        <article class="partner-visual-card">
          <figure class="partner-visual-card__media">
            <img
              src="/images/partner/reel-partners-hotel.webp"
              alt="GuestSafe per hotel, B&B e strutture ricettive con console ospiti e rientro assistito"
              loading="lazy"
            />
          </figure>
          <div class="partner-visual-card__copy">
            <span>Hotel e ospitalità</span>
            <h3>Più supporto alla struttura, più serenità per l'ospite.</h3>
            <p>
              GuestSafe permette a hotel, B&B e agriturismi di offrire agli ospiti informazioni
              locali selezionate, luoghi utili nelle vicinanze, indicazioni di rientro e strumenti
              digitali che rendono il soggiorno più leggibile fin dal primo accesso.
            </p>
            <p>
              La struttura può valorizzare servizi, consigli territoriali e assistenza, mentre
              l'ospite trova percorsi prudenti, punti di interesse e riferimenti utili in un unico
              ambiente coerente con l'esperienza proTcity.
            </p>
          </div>
        </article>

        <article class="partner-visual-card">
          <figure class="partner-visual-card__media">
            <img
              src="/images/partner/reel-partners-comuni.webp"
              alt="proTcity per Comuni con comunicazioni territoriali, eventi locali e notifiche ai cittadini"
              loading="lazy"
            />
          </figure>
          <div class="partner-visual-card__copy">
            <span>Comuni ed enti</span>
            <h3>Comunicazioni territoriali più chiare per cittadini e visitatori.</h3>
            <p>
              I Comuni possono usare proTcity per valorizzare eventi, avvisi, iniziative locali
              e informazioni di prossimità, raggiungendo solo le persone nell'area interessata e
              riducendo dispersione, ripetizioni e messaggi fuori contesto.
            </p>
            <p>
              La dashboard Enti permette di organizzare comunicazioni, leggere risultati aggregati
              e sostenere una città più partecipata, con flussi separati dai partner commerciali e
              ruoli pensati per un uso istituzionale ordinato.
            </p>
          </div>
        </article>

        <article class="partner-visual-card">
          <figure class="partner-visual-card__media">
            <img
              src="/images/partner/reel-comuni-segnalazioni.webp"
              alt="proTcity per Comuni con gestione segnalazioni, stati intervento e dashboard territoriale"
              loading="lazy"
            />
          </figure>
          <div class="partner-visual-card__copy">
            <span>Comuni - Segnalazioni</span>
            <h3>Segnalazioni più ordinate, aggiornamenti più trasparenti.</h3>
            <p>
              La console Segnalazioni aiuta il Comune a ricevere criticità geolocalizzate,
              classificarle per categoria, seguirne lo stato e trasformare conferme e aggiornamenti
              in un flusso più leggibile per uffici, operatori e cittadini.
            </p>
            <p>
              Ogni segnalazione può diventare un elemento operativo: foto, posizione, priorità,
              storico degli stati e indicatori aggregati permettono di ridurre dispersione e
              migliorare la continuità tra ascolto civico e gestione degli interventi.
            </p>
          </div>
        </article>

        <article class="partner-visual-card">
          <figure class="partner-visual-card__media">
            <img
              src="/images/partner/reel-forze-ordine-alert.webp"
              alt="proTcity per forze dell'ordine con gestione alert, conferme community e panoramica territoriale"
              loading="lazy"
            />
          </figure>
          <div class="partner-visual-card__copy">
            <span>Forze dell'ordine - Alert</span>
            <h3>Alert più leggibili per priorità, conferme e contesto urbano.</h3>
            <p>
              Il flusso Alert è pensato per rendere più chiari eventi urgenti o sensibili:
              categoria, posizione, immagini, conferme della community e stato di verifica aiutano
              a distinguere segnalazioni isolate da situazioni che richiedono maggiore attenzione.
            </p>
            <p>
              proTcity non sostituisce centrali operative, numeri di emergenza o procedure ufficiali,
              ma può offrire una vista territoriale ordinata e aggiornata, utile a supportare
              collaborazione urbana, tempestività informativa e tracciabilità degli aggiornamenti.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section id="aziende" class="cinematic-section partner-pricing-section">
    <div class="container">
      <div class="partner-section-heading">
        <p class="eyebrow">Aziende</p>
        <h2>Piani semplici, acquisto diretto e verifica controllata.</h2>
        <p>
          Le tariffe Partner saranno disponibili al lancio ufficiale. Intanto aziende, hotel e
          attività locali possono richiedere accesso anticipato e una proposta dedicata, senza
          fissare pubblicamente prezzi non ancora definitivi.
        </p>
      </div>

      <div class="pricing-grid">
        {businessPlans.map((plan) => (
          <article class:list={["pricing-card", plan.highlighted && "pricing-card--featured"]}>
            {plan.highlighted ? <p class="pricing-card__ribbon">Consigliato</p> : null}
            <div class="pricing-card__body">
              <h2>{plan.name}</h2>
              <p>{plan.subtitle}</p>
              <div class="pricing-card__price">
                <strong>{plan.price}</strong>
                <span>{plan.period}</span>
              </div>
              <a class="pricing-card__button" href={mailtoPlan(plan.subject)}>
                {plan.cta}
              </a>
              <ul>
                {plan.features.map((feature) => <li>{feature}</li>)}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="enti" class="cinematic-band">
    <div class="container">
      <div class="partner-section-heading">
        <p class="eyebrow">Enti Pubblici</p>
        <h2>Un percorso separato per Comuni, territori e istituzioni.</h2>
        <p>
          Per gli Enti il flusso resta su richiesta: raccolta esigenze, proposta, contratto,
          eventuale documentazione amministrativa e attivazione manuale della console Enti.
        </p>
      </div>

      <div class="public-sector-grid">
        {publicSectorPlans.map((plan) => (
          <article class="info-panel">
            <h3>{plan.name}</h3>
            <p>{plan.description}</p>
            <span>Prezzo su richiesta</span>
          </article>
        ))}
      </div>

      <div class="partner-cta-strip">
        <div>
          <h2>Vuoi attivare proTcity per un Comune o un Ente?</h2>
          <p>Prepariamo un percorso dedicato con ruoli, limiti territoriali e gestione segnalazioni.</p>
        </div>
        <Button
          href={mailtoPlan("Richiesta preventivo Enti Pubblici")}
          variant="secondary"
        >
          Richiedi preventivo
        </Button>
      </div>
    </div>
  </section>

  <section class="cinematic-section">
    <div class="container">
      <div class="partner-flow-grid glass-panel">
        <article>
          <span>01</span>
          <h3>Scelta piano</h3>
          <p>L'azienda seleziona Basic, Professional o Enterprise in modo chiaro.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Dati fiscali</h3>
          <p>Ragione sociale e P.IVA vengono associate a una sola organizzazione.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Console Partner</h3>
          <p>Gli utenti autorizzati entrano solo nella propria area e con ruoli controllati.</p>
        </article>
      </div>
    </div>
  </section>
</MainLayout>
