---
import MainLayout from "../layouts/MainLayout.astro";
import { site } from "../data/site";
---

<MainLayout
  title="Contatti"
  description="Contatti proTcity per informazioni generali, supporto, partnership, stampa e privacy."
  canonicalPath="/contact"
  bodyClass="cinematic-site"
>
  <section class="cinematic-hero feature-hero feature-hero--support">
    <div class="cinematic-hero__overlay"></div>
    <div class="container cinematic-hero__content">
      <p class="eyebrow">Contatti</p>
      <h1>Un canale chiaro per ogni esigenza.</h1>
      <p>
        Prodotto, supporto utenti, partner territoriali e privacy: scegli il punto giusto e il team proTcity saprà dove intervenire.
      </p>
      <div class="cinematic-hero__actions">
        <a class="glass-button glass-button--primary" href={`mailto:${site.emails.general}`}>Scrivici</a>
        <a class="glass-button" href="/support">Vai al supporto</a>
      </div>
    </div>
  </section>

  <section class="cinematic-section">
    <div class="container card-grid">
      <article class="contact-card">
        <h3>Informazioni generali</h3>
        <p>Per richieste sul progetto, presentazioni e contatti iniziali.</p>
        <a href={`mailto:${site.emails.general}`}>{site.emails.general}</a>
      </article>
      <article class="contact-card">
        <h3>Supporto utenti</h3>
        <p>Per account, app, segnalazioni e gestione dati personali.</p>
        <a href={`mailto:${site.emails.support}`}>{site.emails.support}</a>
      </article>
      <article class="contact-card">
        <h3>Partner e Comuni</h3>
        <p>Per territori, hotel, strutture ricettive e partnership commerciali.</p>
        <a href={`mailto:${site.emails.business}`}>{site.emails.business}</a>
      </article>
      <article class="contact-card">
        <h3>Privacy</h3>
        <p>Per richieste GDPR, eliminazione dati e informazioni legali.</p>
        <a href={`mailto:${site.emails.privacy}`}>{site.emails.privacy}</a>
      </article>
    </div>
  </section>

  <section class="cinematic-band">
    <div class="container two-column two-column--center glass-panel">
      <div>
        <p class="eyebrow">Dati societari</p>
        <h2>{site.company.legalName}</h2>
        <p>{site.company.city}, {site.company.country}</p>
        <p>{site.company.vat}</p>
      </div>
      <div>
        <a class="glass-button" href="/privacy">Privacy Policy</a>
      </div>
    </div>
  </section>
</MainLayout>
