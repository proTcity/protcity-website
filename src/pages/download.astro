---
import MainLayout from "../layouts/MainLayout.astro";
import { site } from "../data/site";
import { absoluteUrl } from "../utils/seo";

const appStoreCampaignUrl = `${site.stores.appStore}?utm_source=meta&utm_medium=paid_social&utm_campaign=meta_it_download_landing_v1`;

const trustSignals = [
  "Disponibile su App Store",
  "Sviluppata in Italia",
  "Community urbana",
  "Privacy e preferenze sotto controllo"
] as const;

const differentiators = [
  {
    title: "Leggi il territorio",
    text: "La mappa mette in ordine luoghi, contenuti vicini e contesto locale per aiutarti a orientarti con piu consapevolezza."
  },
  {
    title: "Consulta segnali informativi",
    text: "Schede, categorie e dettagli aiutano a capire meglio cosa viene condiviso dalla community e dai soggetti registrati."
  },
  {
    title: "Resta connesso ai contatti fidati",
    text: "Contatti, inviti e preferenze restano sotto controllo dell'utente, senza trasformare l'app in un canale ufficiale."
  }
] as const;

const features = [
  {
    title: "Mappa urbana",
    text: "Visualizza la zona, i punti utili e i contenuti informativi disponibili in un'unica esperienza."
  },
  {
    title: "Segnali informativi",
    text: "Consulta categorie, descrizioni e aggiornamenti pensati per rendere piu leggibile il territorio."
  },
  {
    title: "WalkGuard",
    text: "Prepara un percorso, consulta il contesto locale e scegli strumenti collegati ai tuoi contatti fidati."
  },
  {
    title: "Contatti fidati",
    text: "Gestisci una rete privata di persone importanti per funzioni dedicate, inviti e aggiornamenti."
  },
  {
    title: "Eventi locali",
    text: "Crea e scopri momenti locali con inviti e dettagli chiari."
  },
  {
    title: "Privacy e preferenze",
    text: "Controlla preferenze, permessi e impostazioni dell'app."
  },
  {
    title: "Assistente app",
    text: "Ricevi supporto per comprendere funzioni, preferenze e informazioni disponibili nell'app."
  }
] as const;

const communityTools = [
  {
    image: "/images/app-real/optimized/create-urban-signal.png",
    label: "Nuovo Segnale Urbano",
    title: "Rendi leggibile una problematica urbana",
    text: "Il Segnale Urbano serve a descrivere un contesto di zona, come illuminazione, strada o marciapiede, pulizia urbana, ostacoli o altri elementi utili da conoscere.",
    points: [
      "Usa GPS, punto scelto sulla mappa o indirizzo inserito.",
      "Aiuta cittadini e visitatori a leggere cosa succede intorno.",
      "Se un Comune aderisce a proTcity, può gestire i segnali come quadro informativo della città o del paese, con aggiornamenti visibili nell'app."
    ]
  },
  {
    image: "/images/app-real/optimized/create-alert.png",
    label: "Nuovo Avviso",
    title: "Comunica un contesto temporaneo",
    text: "L'Avviso è pensato per informazioni rapide e contestuali, come un'area affollata, visibilità ridotta, un percorso da rivalutare o un dettaglio temporaneo utile alla community.",
    points: [
      "Organizza titolo, tipo, indirizzo e descrizione.",
      "Resta un contenuto informativo, non un canale ufficiale.",
      "Aiuta la community a orientarsi con più consapevolezza."
    ]
  },
  {
    image: "/images/app-real/optimized/create-event.png",
    label: "Evento Flash",
    title: "Crea momenti locali con inviti chiari",
    text: "Gli Eventi Flash aiutano a proporre attività locali come musica, sport, studio, aperitivi o passeggiate, scegliendo luogo, orario, visibilità e inviti.",
    points: [
      "Può essere aperto a tutti, ai Friends o a persone selezionate.",
      "Compare nella mappa e nelle notifiche di zona quando pubblico.",
      "Favorisce partecipazione locale senza appesantire la mappa."
    ]
  },
  {
    image: "/images/app-real/optimized/create-meetup.png",
    label: "Meetup Spot",
    title: "Proponi luoghi di incontro utili",
    text: "Il Meetup Spot permette di suggerire un punto di incontro, aggiungere dettagli e renderlo visibile alla community con una logica semplice e verificabile.",
    points: [
      "Include posizione, nome, data o ora, recensione e tag.",
      "Può essere pubblico, limitato ai Friends o selettivo.",
      "Aiuta community e cittadini a scoprire luoghi adatti a incontrarsi."
    ]
  }
] as const;

const demoVideos = [
  {
    video: "/videos/download/urban-map-notifications.mp4",
    poster: "/images/app-real/optimized/vicino-a-te-adesso.png",
    label: "Mappa urbana",
    title: "Vicino a te adesso e contenuti sulla mappa",
    text: "Mostra come proTcity organizza contenuti vicini, notifiche e segnali informativi direttamente nella mappa, con una lettura visiva pensata per il contesto urbano.",
    points: ["Contenuti vicini ordinati nella mappa.", "Notifiche e dettagli consultabili senza uscire dal flusso."]
  },
  {
    video: "/videos/download/walkguard.mp4",
    poster: "/images/app-real/optimized/walkguard-download.png",
    label: "WalkGuard",
    title: "Percorsi, contesto e contatti fidati",
    text: "Il video mostra il flusso WalkGuard: scelta del percorso, impostazioni e strumenti informativi collegati alla navigazione e ai contatti selezionati.",
    points: ["Percorso e contesto in un'unica vista.", "Preferenze e contatti controllati dall'utente."]
  },
  {
    video: "/videos/download/urban-signal.mp4",
    poster: "/images/app-real/optimized/create-urban-signal.png",
    label: "Segnale urbano",
    title: "Creare un nuovo segnale informativo",
    text: "Mostra la creazione di un segnale con posizione, categoria, descrizione e opzioni media. Se un Comune o partner aderisce a proTcity, puo usare questi contenuti come quadro informativo ordinato della zona.",
    points: ["Posizione tramite GPS, mappa o indirizzo.", "Categorie chiare per leggere meglio il territorio."]
  },
  {
    video: "/videos/download/community-alert.mp4",
    poster: "/images/app-real/optimized/create-alert.png",
    label: "Avviso",
    title: "Pubblicare un avviso informativo",
    text: "Mostra come inserire un avviso temporaneo per la community, con titolo, indirizzo, tipologia e descrizione del contesto.",
    points: ["Informazioni rapide e contestuali.", "Copy in-app orientato alla responsabilita dell'utente."]
  },
  {
    video: "/videos/download/event-flash.mp4",
    poster: "/images/app-real/optimized/create-event.png",
    label: "Evento",
    title: "Creare un evento flash",
    text: "Mostra il flusso per proporre un evento locale scegliendo categoria, luogo, orario, visibilita e inviti.",
    points: ["Eventi pubblici, Friends o selezionati.", "Presenza nella mappa quando l'evento e pubblico."]
  },
  {
    video: "/videos/download/meetup-spot.mp4",
    poster: "/images/app-real/optimized/create-meetup.png",
    label: "Meetup",
    title: "Proporre un Meetup Spot",
    text: "Mostra come suggerire un punto d'incontro con rating, indirizzo, dettagli, tag e visibilita controllata.",
    points: ["Luoghi d'incontro descritti in modo ordinato.", "Visibilita pubblica o limitata secondo la scelta dell'utente."]
  },
  {
    video: "/videos/download/prevision-settings-ai.mp4",
    poster: "/images/app-real/optimized/impostazioni.png",
    label: "Preferenze",
    title: "PreVision, lingue e assistente AI",
    text: "Mostra preferenze, impostazioni lingua e supporto AI come strumenti informativi e configurabili dall'utente.",
    points: ["Preferenze e lingua in area impostazioni.", "Supporto AI presentato come aiuto informativo."]
  }
] as const;

const screenshots = [
  {
    image: "/images/app-real/optimized/home-mappa.png",
    label: "Home",
    title: "Mappa e contenuti vicini"
  },
  {
    image: "/images/app-real/optimized/segnalazione.png",
    label: "Segnale",
    title: "Dettagli ordinati"
  },
  {
    image: "/images/app-real/optimized/walkguard-download.png",
    label: "WalkGuard",
    title: "Impostazioni percorso"
  },
  {
    image: "/images/app-real/optimized/friends.png",
    label: "Community",
    title: "Inviti e contatti"
  },
  {
    image: "/images/app-real/optimized/impostazioni.png",
    label: "Preferenze",
    title: "Controlli dell'app"
  }
] as const;

const audiences = [
  {
    title: "Cittadini",
    text: "Per leggere meglio ciò che succede nella propria zona e consultare contenuti locali."
  },
  {
    title: "Visitatori",
    text: "Per orientarsi in aree nuove con una mappa pensata per il contesto urbano."
  },
  {
    title: "Studenti",
    text: "Per muoversi tra casa, università, mezzi e luoghi frequentati con informazioni più ordinate."
  },
  {
    title: "Pendolari",
    text: "Per controllare percorsi, punti utili e aggiornamenti locali durante gli spostamenti."
  },
  {
    title: "Community locali",
    text: "Per condividere momenti, inviti e informazioni utili con un linguaggio chiaro."
  }
] as const;

const downloadReasons = [
  {
    title: "Disponibile ora su iPhone",
    text: "Puoi provarla subito da App Store e iniziare a esplorare la mappa urbana nella tua zona."
  },
  {
    title: "Funzioni gia pronte da testare",
    text: "Mappa, segnali informativi, WalkGuard, contatti fidati, eventi e meetup sono parte del flusso attuale."
  },
  {
    title: "Community in costruzione",
    text: "Ogni nuovo utente contribuisce a validare il linguaggio, la qualita dei contenuti e l'utilita reale del servizio."
  },
  {
    title: "Controllo delle preferenze",
    text: "Permessi, privacy, lingua e notifiche sono gestibili dall'utente secondo le impostazioni disponibili."
  }
] as const;

const faqs = [
  {
    question: "proTcity è gratuita?",
    answer: "Sì, proTcity è disponibile gratuitamente su App Store."
  },
  {
    question: "È disponibile per Android?",
    answer: "Al momento proTcity è disponibile per iPhone. La versione Google Play è in arrivo."
  },
  {
    question: "proTcity è un'app ufficiale delle autorità?",
    answer: "No. proTcity è un'app privata e indipendente pensata per aiutare utenti e community a leggere meglio il contesto urbano."
  },
  {
    question: "Le informazioni sono sempre verificate?",
    answer: "proTcity può includere informazioni provenienti dalla community e dati disponibili pubblicamente. Alcuni contenuti possono essere indicati come non verificati o in attesa di conferma."
  },
  {
    question: "A cosa serve WalkGuard?",
    answer: "WalkGuard aiuta a seguire un percorso mantenendo visibile il contesto locale e alcuni strumenti rapidi durante lo spostamento."
  },
  {
    question: "Cosa sono i segnali informativi?",
    answer: "Sono contenuti contestuali pubblicati nella mappa per descrivere luoghi, dettagli urbani o informazioni utili alla community. Non sono istruzioni operative e non sostituiscono canali ufficiali."
  },
  {
    question: "Posso usare proTcity quando visito una città nuova?",
    answer: "Sì. proTcity può aiutarti a orientarti meglio, consultare punti utili e leggere il contesto intorno a te."
  },
  {
    question: "proTcity usa tracking pubblicitario?",
    answer: "La pagina download non inserisce pixel pubblicitari, SDK esterni o script di remarketing. Eventuali strumenti non necessari devono essere attivati solo con consenso ove richiesto."
  },
  {
    question: "proTcity sostituisce i canali ufficiali per situazioni urgenti?",
    answer: "No. proTcity non sostituisce servizi pubblici, autorità o numeri ufficiali. In caso di necessità reale bisogna sempre contattare i canali competenti."
  }
] as const;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Scarica proTcity",
    url: absoluteUrl("/download"),
    description:
      "Scarica proTcity su App Store: mappa urbana/community, segnali informativi, WalkGuard, contatti fidati e contesto locale per orientarti meglio nel territorio.",
    isPartOf: {
      "@type": "WebSite",
      name: site.name,
      url: absoluteUrl("/")
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    name: "proTcity",
    applicationCategory: "LifestyleApplication",
    operatingSystem: "iOS",
    url: site.stores.appStore,
    image: absoluteUrl("/images/app-preview.png"),
    publisher: {
      "@type": "Organization",
      name: site.company.legalName,
      url: absoluteUrl("/")
    },
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "EUR",
      availability: "https://schema.org/InStock",
      url: site.stores.appStore
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
      "@type": "Question",
      name: faq.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.answer
      }
    }))
  }
];
---

<MainLayout
  title="Scarica proTcity | App Store e mappa urbana community"
  description="Scarica proTcity su App Store: mappa urbana/community per leggere il territorio, consultare segnali informativi, usare WalkGuard e gestire contatti fidati. Google Play in arrivo."
  canonicalPath="/download"
  image="/images/app-preview.png"
  ogTitle="Scarica proTcity su App Store"
  ogDescription="Non e una semplice mappa: proTcity aiuta cittadini e visitatori a leggere meglio il territorio e restare connessi ai contatti fidati."
  bodyClass="download-page cinematic-site"
  schema={schema}
>
  <section class="download-hero" aria-labelledby="download-title">
    <div class="container download-hero__grid">
      <div class="download-hero__copy">
        <p class="cinematic-kicker">Disponibile ora per iPhone</p>
        <h1 id="download-title">Non è una semplice mappa.</h1>
        <p class="download-hero__lead">
          proTcity aiuta cittadini e visitatori a leggere meglio il territorio, orientarsi con piu consapevolezza e restare connessi ai propri contatti fidati.
        </p>
        <div class="cinematic-actions" aria-label="Azioni principali">
          <a class="glass-button glass-button--primary" href={appStoreCampaignUrl} target="_blank" rel="noopener noreferrer">Scarica su App Store</a>
          <a class="glass-button" href="#come-funziona">Scopri come funziona</a>
        </div>
        <div class="store-badges" aria-label="Disponibilita sugli store">
          <a class="store-badge store-badge--apple" href={appStoreCampaignUrl} target="_blank" rel="noopener noreferrer" aria-label="Scarica proTcity su App Store">
            <img src="/images/store/app-store-badge.svg" alt="Download on the App Store" loading="eager" decoding="async" />
          </a>
          <span class="store-badge store-badge--disabled" aria-disabled="true">
            <img src="/images/store/google-play-badge.png" alt="Disponibile su Google Play" loading="eager" decoding="async" />
            <span>In arrivo</span>
          </span>
        </div>
        <p class="download-hero__note">Disponibile ora per iPhone. Google Play in arrivo.</p>
      </div>

      <div class="download-hero__visual" aria-label="Schermata reale della mappa proTcity">
        <figure class="download-phone download-phone--main">
          <img src="/images/app-real/optimized/home-mappa.png" alt="Mappa urbana di proTcity su iPhone" decoding="async" />
          <figcaption>Mappa urbana</figcaption>
        </figure>
        <figure class="download-phone download-phone--side" aria-hidden="true">
          <img src="/images/app-real/optimized/walkguard2.png" alt="" decoding="async" />
        </figure>
      </div>
    </div>
  </section>

  <section class="download-trust" aria-label="Elementi di fiducia">
    <div class="container download-trust__grid">
      {trustSignals.map((signal) => (
        <span>{signal}</span>
      ))}
    </div>
  </section>

  <section class="download-section download-section--raised" id="come-funziona" aria-labelledby="difference-title">
    <div class="container">
      <div class="download-section__intro">
        <p class="cinematic-kicker">Per orientarti meglio</p>
        <h2 id="difference-title">La mappa urbana che mette ordine al contesto intorno a te.</h2>
        <p>
          proTcity non promette interventi, non sostituisce canali ufficiali e non invita ad agire fisicamente: organizza informazioni e strumenti per leggere meglio cio che hai intorno.
        </p>
      </div>
      <div class="download-benefit-grid">
        {differentiators.map((benefit) => (
          <article class="download-card">
            <span>{benefit.title}</span>
            <p>{benefit.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="download-section" aria-labelledby="features-title">
    <div class="container download-split">
      <div class="download-section__intro">
        <p class="cinematic-kicker">Funzioni principali</p>
        <h2 id="features-title">Cosa puoi fare con proTcity</h2>
        <p>
          Ogni funzione è pensata per mappa, community e contesto locale: contenuti brevi, categorie chiare e preferenze sempre gestibili.
        </p>
        <div class="cinematic-actions">
          <a class="glass-button glass-button--primary" href={appStoreCampaignUrl} target="_blank" rel="noopener noreferrer">Scarica su App Store</a>
        </div>
      </div>
      <div class="download-feature-grid">
        {features.map((feature) => (
          <article>
            <h3>{feature.title}</h3>
            <p>{feature.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="download-section download-section--screens" aria-labelledby="screens-title">
    <div class="container">
      <div class="download-section__intro download-section__intro--center">
        <p class="cinematic-kicker">Screenshot reali</p>
        <h2 id="screens-title">Guarda proTcity in azione</h2>
        <p>
          Schermate dell'app reale: mappa, segnali, percorso, community e preferenze restano leggibili anche da mobile.
        </p>
      </div>
      <div class="download-screen-grid">
        {screenshots.map((screen) => (
          <figure class="download-screen-card">
            <img src={screen.image} alt={`${screen.title} in proTcity`} loading="lazy" decoding="async" />
            <figcaption>
              <span>{screen.label}</span>
              <strong>{screen.title}</strong>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="download-section download-section--community-tools" aria-labelledby="community-tools-title">
    <div class="container">
      <div class="download-section__intro download-section__intro--center">
        <p class="cinematic-kicker">Community e territorio</p>
        <h2 id="community-tools-title">Crea segnali, avvisi, eventi e meetup utili alla zona</h2>
        <p>
          proTcity permette di pubblicare contenuti informativi e momenti locali con categorie chiare, posizione e visibilità controllata. Per cittadini e community significa leggere meglio il territorio; per Comuni o partner registrati significa avere un quadro più ordinato delle problematiche urbane segnalate.
        </p>
      </div>
      <div class="download-community-grid">
        {communityTools.map((tool) => (
          <article class="download-community-card">
            <figure>
              <img src={tool.image} alt={`${tool.label} in proTcity`} loading="lazy" decoding="async" />
            </figure>
            <div>
              <span>{tool.label}</span>
              <h3>{tool.title}</h3>
              <p>{tool.text}</p>
              <ul>
                {tool.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="download-section download-section--videos" aria-labelledby="videos-title">
    <div class="container">
      <div class="download-section__intro download-section__intro--center">
        <p class="cinematic-kicker">Video reali dell'app</p>
        <h2 id="videos-title">Guarda i flussi principali prima di scaricare.</h2>
        <p>
          Video dimostrativi registrati dall'app: mappa, WalkGuard, segnali, avvisi, eventi, meetup, preferenze e supporto informativo.
        </p>
      </div>
      <div class="download-video-grid">
        {demoVideos.map((item) => (
          <article class="download-video-card">
            <div class="download-video-card__media">
              <video
                controls
                playsinline
                preload="none"
                poster={item.poster}
                aria-label={`${item.title} in proTcity`}
              >
                <source src={item.video} type="video/mp4" />
              </video>
            </div>
            <div class="download-video-card__body">
              <span>{item.label}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
              <ul>
                {item.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="download-section" aria-labelledby="audience-title">
    <div class="container">
      <div class="download-section__intro">
        <p class="cinematic-kicker">Per chi è utile</p>
        <h2 id="audience-title">Pensata per cittadini, visitatori e community locali</h2>
      </div>
      <div class="download-audience-grid">
        {audiences.map((audience) => (
          <article>
            <h3>{audience.title}</h3>
            <p>{audience.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="download-section download-section--reasons" aria-labelledby="reasons-title">
    <div class="container">
      <div class="download-section__intro download-section__intro--center">
        <p class="cinematic-kicker">Perche scaricarla ora</p>
        <h2 id="reasons-title">Inizia dalla tua zona e guarda come cambia la lettura della mappa.</h2>
      </div>
      <div class="download-reason-grid">
        {downloadReasons.map((reason) => (
          <article>
            <h3>{reason.title}</h3>
            <p>{reason.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="download-section download-section--faq" aria-labelledby="faq-title">
    <div class="container download-faq">
      <div class="download-section__intro">
        <p class="cinematic-kicker">FAQ</p>
        <h2 id="faq-title">Domande frequenti</h2>
      </div>
      <div class="download-faq__list">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="download-final" aria-labelledby="final-download-title">
    <div class="container download-final__inner">
      <div class="download-final__brand" aria-hidden="true">
        <img src="/apple-touch-icon.png" alt="" loading="lazy" decoding="async" />
        <img src="/images/logo-tm.png" alt="" loading="lazy" decoding="async" />
      </div>
      <p class="cinematic-kicker">App Store</p>
      <h2 id="final-download-title">Scarica proTcity e porta la mappa urbana sul tuo iPhone.</h2>
      <p>Disponibile ora su App Store. Google Play in arrivo.</p>
      <div class="cinematic-actions">
        <a class="glass-button glass-button--primary" href={appStoreCampaignUrl} target="_blank" rel="noopener noreferrer">Scarica su App Store</a>
