---
import MainLayout from "../layouts/MainLayout.astro";
import { appCapabilities } from "../data/features";
import { site } from "../data/site";
import { absoluteUrl } from "../utils/seo";

const appStoreUrl = site.stores.appStore;
const playStoreUrl = site.stores.playStore;

const schema = {
  "@context": "https://schema.org",
  "@type": "MobileApplication",
  name: "proTcity",
  applicationCategory: "SafetyApplication",
  operatingSystem: "iOS, Android",
  description:
    "App mobile per sicurezza urbana collaborativa con mappa, alert, WalkGuard, SOS, segnalazioni, contatti fidati e assistente AI.",
  url: absoluteUrl("/app"),
  sameAs: [appStoreUrl, playStoreUrl],
  downloadUrl: [appStoreUrl, playStoreUrl],
  image: absoluteUrl("/images/app-preview.png"),
  publisher: {
    "@type": "Organization",
    name: site.company.legalName,
    url: absoluteUrl("/")
  },
  offers: [
    {
      "@type": "Offer",
      price: "0",
      priceCurrency: "EUR",
      availability: "https://schema.org/InStock",
      url: appStoreUrl
    },
    {
      "@type": "Offer",
      price: "0",
      priceCurrency: "EUR",
      availability: "https://schema.org/InStock",
      url: playStoreUrl
    }
  ]
};
---

<MainLayout
  title="App mobile"
  description="La pagina dedicata all'app proTcity: mappa, alert, WalkGuard, contatti fidati e strumenti di sicurezza personale."
  canonicalPath="/app"
  bodyClass="cinematic-site"
  schema={schema}
>
  <section class="cinematic-hero feature-hero feature-hero--app">
    <div class="cinematic-hero__media"></div>
    <div class="cinematic-hero__shade"></div>
    <div class="container cinematic-hero__content">
      <p class="eyebrow">App mobile</p>
      <h1>Una sola esperienza per leggere la città e agire meglio.</h1>
      <p class="cinematic-hero__lead">
        Mappa, alert, segnalazioni, WalkGuard, SOS, notifiche e assistente AI convivono in una schermata pensata per essere chiara anche quando il contesto cambia rapidamente.
      </p>
      <div class="cinematic-hero__actions">
        <a class="glass-button glass-button--primary" href={appStoreUrl} target="_blank" rel="noopener noreferrer">Scarica su App Store</a>
        <a class="glass-button glass-button--primary" href={playStoreUrl} target="_blank" rel="noopener noreferrer">Scarica su Google Play</a>
        <a class="glass-button" href="/walkguard">Scopri WalkGuard</a>
      </div>
      <div class="store-badges" aria-label="Disponibilita sugli store">
        <a class="store-badge store-badge--apple" href={appStoreUrl} target="_blank" rel="noopener noreferrer" aria-label="Scarica proTcity su App Store">
          <img src="/images/store/app-store-badge.svg" alt="Download on the App Store" loading="eager" decoding="async" />
        </a>
        <a class="store-badge store-badge--google" href={playStoreUrl} target="_blank" rel="noopener noreferrer" aria-label="Scarica proTcity su Google Play">
          <img src="/images/store/google-play-badge.png" alt="Disponibile su Google Play" loading="eager" decoding="async" />
        </a>
      </div>
    </div>
  </section>

  <section class="signal-strip signal-strip--floating">
    <div class="container">
      <div class="signal-strip__grid">
        {appCapabilities.slice(0, 3).map((item, index) => (
          <article>
            <span>0{index + 1}</span>
            <h3>{item}</h3>
            <p>Funzione integrata nell'esperienza mobile, pensata per restare vicina all'utente senza riempire la mappa di rumore.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cinematic-section">
    <div class="container poster-grid poster-grid--four">
      <article class="liquid-poster">
        <img src="/images/app-real/optimized/segnalazione.png" alt="Schermata reale di una segnalazione in proTcity" loading="lazy" />
        <div class="liquid-poster__body">
          <h3>Alert e segnalazioni</h3>
          <p>La community informa, conferma e aiuta a rendere più leggibile ciò che accade nelle vicinanze.</p>
        </div>
      </article>
      <article class="liquid-poster">
        <img src="/images/app-real/optimized/sos.png" alt="Schermata reale SOS di proTcity" loading="lazy" />
        <div class="liquid-poster__body">
          <h3>SOS vicino alla mano</h3>
          <p>Un comando rapido, discreto e integrato con contatti fidati e contesto di posizione.</p>
        </div>
      </article>
      <article class="liquid-poster">
        <img src="/images/features/optimized/community-cane-smarrito.webp" alt="Community proTcity per segnalazioni utili" loading="lazy" />
        <div class="liquid-poster__body">
          <h3>Community utile</h3>
          <p>Segnali concreti, verificabili e rispettosi: la collaborazione deve aumentare fiducia, non ansia.</p>
        </div>
      </article>
      <article class="liquid-poster">
        <img src="/images/app-real/optimized/walkguard6.png" alt="Schermata reale WalkGuard in proTcity" loading="lazy" />
        <div class="liquid-poster__body">
          <h3>Ogni momento</h3>
          <p>Dalla mattina alla sera, l'app adatta informazioni e strumenti al contesto reale.</p>
        </div>
      </article>
    </div>
  </section>
</MainLayout>
