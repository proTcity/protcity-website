---
import LegalLayout from "../layouts/LegalLayout.astro";
import { companyInfo, contactEmails } from "../data/site";
import { legalMeta } from "../data/legal";

const legalBases = [
  ["Account, autenticazione e sicurezza accessi", "Esecuzione del servizio; legittimo interesse alla sicurezza; obblighi legali ove applicabili."],
  ["Geolocalizzazione, mappa, segnalazioni, alert e WalkGuard", "Consenso per la posizione precisa ove richiesto dal sistema operativo; esecuzione del servizio richiesto; legittimo interesse alla sicurezza e prevenzione abusi."],
  ["SOS, Guardian/Buddy e funzioni di sicurezza personale", "Consenso ed esecuzione del servizio; tutela di interessi vitali solo nei casi strettamente necessari e compatibili con la legge."],
  ["Moderazione contenuti, abuso, frodi e sicurezza piattaforma", "Legittimo interesse; obblighi legali; accertamento, esercizio o difesa di diritti."],
  ["AI, Safety Score e spiegazioni contestuali", "Esecuzione del servizio; legittimo interesse a fornire informazioni contestuali prudenti; consenso ove richiesto per dati specifici."],
  ["Comunicazioni, supporto e richieste privacy", "Esecuzione del servizio; obblighi legali; legittimo interesse alla gestione delle richieste."],
  ["Pagamenti partner tramite Stripe o PayPal", "Esecuzione di misure precontrattuali/contratto; obblighi fiscali e contabili; legittimo interesse antifrode."],
  ["Cookie non tecnici e analytics non essenziali", "Consenso, ove tali strumenti siano attivati."],
];

const providers = [
  ["Firebase / Google Cloud", "Autenticazione, database, storage immagini, funzioni backend, log tecnici e sicurezza.", "Dati account, ID tecnici, contenuti inviati, media, log, dati di geolocalizzazione connessi alle funzioni.", "Responsabile del trattamento o fornitore cloud, secondo i contratti applicabili."],
  ["Firebase Authentication", "Creazione account, accesso anonimo o autenticato, eventuale login email/social.", "Email, identificativi account, UID Firebase, token tecnici.", "Responsabile/servizio Google Cloud."],
  ["Firestore", "Conservazione dati applicativi: segnalazioni, alert, preferenze, log funzionali, audit essenziali.", "Dati inseriti dall'utente, coordinate, stati segnalazioni, conferme, dati console.", "Responsabile/servizio Google Cloud."],
  ["Firebase Storage", "Caricamento e conservazione immagini e media allegati.", "Immagini, metadati tecnici, riferimenti alla segnalazione o alert.", "Responsabile/servizio Google Cloud."],
  ["Mapbox", "Mappe, geocoding, routing, contesto territoriale e percorsi.", "Coordinate, query indirizzo, dati tecnici dispositivo e uso API.", "Fornitore terzo; ruolo secondo policy e contratti Mapbox."],
  ["OpenAI", "Supporto AI, spiegazioni Safety Score, assistenza app e analisi testuale controllata lato backend.", "Prompt minimizzati, contesto urbano, testi necessari, dati tecnici strettamente utili.", "Fornitore AI; trattamento secondo accordi e impostazioni applicabili."],
  ["Cloudflare", "Hosting, CDN, sicurezza, protezione traffico, DNS e log tecnici del sito.", "IP, log richieste, dati tecnici browser, sicurezza rete.", "Responsabile/fornitore infrastrutturale secondo servizi attivi."],
  ["Vercel", "Hosting o deploy di console e componenti web ove attivi.", "Log tecnici, IP, dati di accesso e deploy.", "Responsabile/fornitore infrastrutturale."],
  ["GitHub", "Repository, versionamento codice, eventuali workflow di deploy.", "Dati sviluppatori, log tecnici, codice e issue operative.", "Fornitore autonomo o responsabile secondo uso effettivo."],
  ["Stripe", "Pagamenti, abbonamenti partner, fatturazione, prevenzione frodi.", "Dati aziendali, email, P.IVA, piano scelto, ID cliente, pagamento, stato abbonamento. proTcity non conserva il numero completo della carta.", "Provider di pagamento, anche autonomo per obblighi antifrode/compliance."],
  ["PayPal", "Pagamenti partner e gestione abbonamenti ove attiva.", "Dati account PayPal, email, transazione, piano, stato pagamento. proTcity riceve solo esiti e riferimenti necessari.", "Provider di pagamento, anche autonomo per obblighi propri."],
  ["Servizi email/form", "Contatti, supporto, richieste privacy, lead partner.", "Nome, email, messaggio, dati tecnici del form.", "Da confermare nel registro fornitori prima della pubblicazione definitiva."],
  ["Analytics", "Statistiche tecniche e miglioramento servizio, solo se attivati.", "Eventi aggregati, dati tecnici, ID pseudonimi.", "Da confermare e sottoporre a consenso se non strettamente tecnico."],
];

const retentionRows = [
  ["Account utente", "Per la durata dell'account e, dopo chiusura, per il tempo necessario a completare cancellazione, obblighi legali e sicurezza."],
  ["Segnalazioni e alert", "Per il tempo necessario alla finalità urbana, moderazione, storico essenziale e difesa da abusi; durata definitiva da approvare nel registro retention."],
  ["Coordinate e posizione collegate a segnalazioni", "Conservate solo se necessarie a mostrare, verificare o gestire la segnalazione; non usate per tracciare inutilmente gli spostamenti."],
  ["Posizione live WalkGuard/SOS/Buddy", "Solo per la sessione attiva o per il periodo strettamente necessario alla funzione; eventuali log di sicurezza sono limitati."],
  ["Immagini e media", "Finché la segnalazione resta attiva o fino a rimozione/moderazione; contenuti illeciti possono essere conservati in log limitati per difesa e abuso."],
  ["Log tecnici e sicurezza", "Indicativamente 6-24 mesi, salvo incidenti, frodi, obblighi legali o necessità di difesa."],
  ["Moderazione e audit", "Per il tempo necessario a dimostrare gestione abusi, decisioni e contestazioni; durata definitiva da validare legalmente."],
  ["Pagamenti, fatture e dati partner", "Per la durata del rapporto e secondo obblighi fiscali, contabili e civilistici, normalmente fino a 10 anni ove applicabile."],
  ["Supporto e richieste privacy", "Per il tempo necessario a rispondere e dimostrare la gestione della richiesta; indicativamente fino a 24 mesi salvo contenziosi."],
  ["Cookie e log sito", "Secondo durata indicata nella Cookie Policy e configurazioni tecniche effettive."],
];
---

<LegalLayout
  title="Privacy Policy e GDPR"
  description="Informativa sul trattamento dei dati personali nell'app proTcity, nel sito protcity.com e nei servizi collegati."
  canonicalPath="/privacy"
>
  <p class="legal-warning">
    Questa informativa è predisposta per la pubblicazione web e deve essere mantenuta allineata alle funzioni realmente attive. Le parti indicate come "ove attivo", "quando implementato" o "se abilitato" non devono essere interpretate come funzioni già disponibili per tutti gli utenti.
  </p>

  <h2>1. Titolare del trattamento</h2>
  <p>
    Il titolare del trattamento è <strong>{companyInfo.name}</strong>, con sede in <strong>{companyInfo.address}</strong>, P.IVA <strong>{companyInfo.vat}</strong>, REA <strong>{companyInfo.rea}</strong>, telefono <strong>{companyInfo.phone}</strong>.
  </p>
  <p>
    Per richieste privacy: <a href={`mailto:${contactEmails.privacy}`}>{contactEmails.privacy}</a>. Per assistenza sull'app: <a href={`mailto:${contactEmails.support}`}>{contactEmails.support}</a>.
  </p>
  <p>
    DPO/RPD: Kurbi Labs s.r.l.s. valuterà la nomina del Responsabile della Protezione dei Dati secondo gli articoli 37-39 GDPR. Se nominato, i relativi recapiti saranno pubblicati in questa pagina.
  </p>

  <h2>2. Ambito di applicazione</h2>
  <p>
    La presente informativa riguarda l'app mobile proTcity, il sito <strong>protcity.com</strong>, le console amministrative e partner/enti, le comunicazioni email, i moduli di contatto, le funzioni di segnalazione, alert, sicurezza urbana, AI, pagamenti partner e, quando attive, le notifiche push.
  </p>

  <h2>3. Tipologie di dati trattati</h2>
  <ul>
    <li>dati identificativi e di contatto: email, nome o denominazione aziendale/ente, telefono se comunicato, P.IVA o dati contrattuali partner;</li>
    <li>dati account: UID Firebase, accesso anonimo, identificativi tecnici, stato account, ruoli admin/partner/ente;</li>
    <li>dati tecnici: IP, dispositivo, sistema operativo, log, eventi sicurezza, crash e diagnostica ove attivi;</li>
    <li>geolocalizzazione precisa o approssimativa: coordinate GPS, posizione corrente, indirizzi ricavati da geocoding, zona di segnalazione;</li>
    <li>contenuti generati dagli utenti: segnalazioni, alert, categorie, note, conferme, visualizzazioni, immagini e metadati;</li>
    <li>dati SOS, Buddy/Guardian e WalkGuard: destinazione, percorso, stato sessione, condivisione temporanea con contatti fidati, ove attiva;</li>
    <li>dati di moderazione: report, motivi, note, esiti, log di decisione, sospensioni o ban;</li>
    <li>dati AI derivati: Safety Score, Confidence Score, spiegazioni, motivazioni tecniche, audit sintetici;</li>
    <li>token notifiche push, se le notifiche native vengono abilitate;</li>
    <li>dati di pagamento partner: piano selezionato, stato abbonamento, ID transazione, fatturazione, ricevute, Stripe/PayPal customer ID;</li>
    <li>dati del sito: cookie tecnici, preferenze consenso, moduli contatto, log sicurezza.</li>
  </ul>

  <h2>4. Geolocalizzazione precisa</h2>
  <p>
    proTcity usa la geolocalizzazione per mostrare la posizione sulla mappa, creare segnalazioni e alert geolocalizzati, calcolare percorsi WalkGuard, suggerire Safe Points, limitare pubblicazioni lontane dalla posizione reale dell'utente, abilitare funzioni SOS/Buddy e produrre indicatori di contesto urbano come Safety Score.
  </p>
  <p>
    La posizione precisa viene richiesta tramite i permessi del sistema operativo. L'app può usare la posizione in foreground durante l'utilizzo della mappa e, solo se l'utente abilita funzioni specifiche come WalkGuard, Guardian/Buddy o SOS, può trattarla per una sessione di sicurezza o monitoraggio. L'uso in background, ove implementato, deve essere chiaro, volontario e revocabile.
  </p>
  <p>
    proTcity non dovrebbe conservare uno storico dettagliato e permanente degli spostamenti dell'utente. Quando una posizione viene associata a una segnalazione o a un alert, viene conservata perché necessaria a rendere utile e verificabile il contenuto urbano. L'utente può revocare i permessi di localizzazione dalle impostazioni del dispositivo; alcune funzioni potrebbero non funzionare senza tale permesso.
  </p>

  <h2>5. Finalità del trattamento</h2>
  <ul>
    <li>creare, autenticare e proteggere account utente, admin, partner ed enti;</li>
    <li>visualizzare mappe, percorsi, indirizzi, segnalazioni e alert vicini;</li>
    <li>consentire la pubblicazione, conferma, revisione e gestione di segnalazioni e alert;</li>
    <li>fornire funzioni SOS, WalkGuard, Buddy/Guardian e rientro sicuro, nei limiti del servizio;</li>
    <li>moderare contenuti, immagini, abusi, fake report, spam e contenuti offensivi;</li>
    <li>generare Safety Score, Confidence Score e spiegazioni AI informative e non vincolanti;</li>
    <li>inviare notifiche push e comunicazioni di servizio, quando abilitate;</li>
    <li>gestire pagamenti, abbonamenti partner, fatturazione, antifrode e rinnovi tramite Stripe o PayPal;</li>
    <li>rispondere a richieste di supporto, privacy, cancellazione dati e contestazioni;</li>
    <li>adempiere obblighi legali e tutelare diritti, sicurezza e integrità della piattaforma.</li>
  </ul>

  <h2>6. Basi giuridiche GDPR</h2>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Finalità</th><th>Base giuridica</th></tr></thead>
      <tbody>
        {legalBases.map(([purpose, basis]) => <tr><td>{purpose}</td><td>{basis}</td></tr>)}
      </tbody>
    </table>
  </div>

  <h2>7. Funzioni specifiche dell'app</h2>
  <h3>Account, accesso anonimo e login social</h3>
  <p>
    L'app può usare Firebase Authentication per accesso anonimo, email o, se implementato, login social. In caso di login social, proTcity riceve solo i dati necessari dal provider, come email, nome pubblico e identificativo account, secondo i permessi concessi dall'utente.
  </p>
  <h3>Mappa, Mapbox e percorsi</h3>
  <p>
    Mapbox supporta mappa, geocoding, ricerca luoghi e routing. Le richieste possono includere coordinate, indirizzi cercati, percorso e dati tecnici necessari al servizio.
  </p>
  <h3>Segnalazioni, alert e immagini</h3>
  <p>
    Gli utenti possono inviare segnalazioni e alert geolocalizzati con testi, categorie, note e immagini. Le immagini possono contenere dati personali di terzi: è vietato caricare volti riconoscibili, minori, targhe, documenti, dati sanitari, scene violente, accuse personali o contenuti illeciti salvo stretta necessità e base giuridica.
  </p>
  <h3>SOS, WalkGuard e sicurezza personale</h3>
  <p>
    Queste funzioni aiutano l'utente a orientarsi o condividere temporaneamente informazioni di sicurezza. proTcity non sostituisce il 112, 113, 118, forze dell'ordine, vigili del fuoco, servizi sanitari o altre autorità competenti.
  </p>
  <h3>Safety Score e AI</h3>
  <p>
    Il Safety Score è un indicatore informativo basato su segnali urbani, segnalazioni, contesto territoriale e fonti disponibili. Non valuta persone fisiche, non identifica soggetti, non predice reati individuali e non sostituisce decisioni umane o autorità pubbliche.
  </p>
  <h3>Admin Console e Partner/Enti</h3>
  <p>
    Le console consentono a personale autorizzato di gestire contenuti, segnalazioni, partner, enti, ruoli, abbonamenti e interventi. Gli accessi sono limitati per ruolo e devono essere tracciati in modo proporzionato.
  </p>

  <h2>8. Moderazione contenuti</h2>
  <p>
    proTcity può applicare controlli automatici e revisione manuale per rimuovere o limitare contenuti falsi, offensivi, pericolosi, abusivi, discriminatori, spam, lesivi di terzi o contrari alle regole community. Gli utenti possono segnalare contenuti e bloccare utenti abusivi. Kurbi Labs può conservare log di moderazione necessari a sicurezza, contestazioni e difesa.
  </p>

  <h2>9. Pagamenti partner con Stripe e PayPal</h2>
  <p>
    Quando i piani partner sono attivati, aziende e professionisti possono pagare tramite Stripe o PayPal. proTcity non conserva il numero completo della carta, il CVV o credenziali PayPal. Riceve e conserva solo dati necessari a gestire piano, fatturazione, stato abbonamento, rinnovi, contestazioni e obblighi fiscali.
  </p>
  <p>
    Stripe e PayPal trattano dati di pagamento anche secondo le rispettive informative privacy e obblighi normativi propri, inclusi antifrode, sicurezza, compliance finanziaria e contabile.
  </p>

  <h2>10. Fornitori e piattaforme terze</h2>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Fornitore</th><th>Finalità</th><th>Dati</th><th>Ruolo privacy</th></tr></thead>
      <tbody>
        {providers.map(([name, purpose, data, role]) => <tr><td>{name}</td><td>{purpose}</td><td>{data}</td><td>{role}</td></tr>)}
      </tbody>
    </table>
  </div>

  <h2>11. Trasferimenti internazionali</h2>
  <p>
    Alcuni provider possono trattare dati fuori dallo Spazio Economico Europeo, in particolare negli Stati Uniti o in altri Paesi. Quando necessario, Kurbi Labs deve verificare l'esistenza di decisioni di adeguatezza, Standard Contractual Clauses, misure supplementari, configurazioni regionali, DPA e impostazioni di sicurezza.
  </p>

  <h2>12. Conservazione dei dati</h2>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Categoria</th><th>Criterio di conservazione</th></tr></thead>
      <tbody>
        {retentionRows.map(([category, time]) => <tr><td>{category}</td><td>{time}</td></tr>)}
      </tbody>
    </table>
  </div>

  <h2>13. Diritti degli utenti</h2>
  <p>
    Gli utenti possono chiedere accesso, rettifica, cancellazione, limitazione, opposizione, portabilità, revoca del consenso e informazioni sui trattamenti. Le richieste vanno inviate a <a href={`mailto:${contactEmails.privacy}`}>{contactEmails.privacy}</a>. È possibile proporre reclamo al Garante per la protezione dei dati personali o all'autorità competente del proprio Paese.
  </p>

  <h2>14. Minori</h2>
  <p>
    proTcity non è progettata per raccogliere intenzionalmente dati di minori senza adeguata base giuridica o consenso genitoriale ove richiesto. È vietato pubblicare immagini, dati o informazioni che rendano identificabile un minore, salvo casi legittimi e proporzionati. L'età minima definitiva deve essere validata prima della pubblicazione sugli store.
  </p>

  <h2>15. Sicurezza</h2>
  <p>
    proTcity adotta misure tecniche e organizzative ragionevoli: autenticazione, regole Firestore/Storage, accessi per ruolo, cifratura in transito, logging proporzionato, protezione API key lato server, monitoraggio abusi e separazione tra client e backend per chiavi sensibili come OpenAI, Stripe e PayPal.
  </p>

  <h2>16. Normative extra UE</h2>
  <p>
    Per utenti fuori dall'Unione Europea possono applicarsi norme locali come UK GDPR, CCPA/CPRA, PIPEDA, LGPD, APPI o altre leggi privacy. Kurbi Labs gestirà le richieste secondo la normativa applicabile, tenendo conto della sede dell'utente, del servizio utilizzato e del ruolo effettivo della società.
  </p>

  <h2>17. Cookie</h2>
  <p>
    Il sito può usare cookie tecnici e, solo se attivati e previo consenso ove necessario, strumenti analytics o marketing. I dettagli sono disponibili nella <a href="/cookie-policy">Cookie Policy</a>.
  </p>

  <h2>18. Aggiornamenti</h2>
  <p>
    Kurbi Labs può aggiornare questa informativa in caso di nuove funzioni, modifiche ai provider, obblighi legali o cambiamenti tecnici. La versione pubblicata indica la data di aggiornamento: <strong>{legalMeta.lastUpdated}</strong>.
  </p>

  <h2>Punti da verificare con consulente privacy/DPO</h2>
  <ul>
    <li>nomina DPO/RPD e recapiti, se richiesta o opportuna;</li>
    <li>DPIA per geolocalizzazione precisa, AI Safety Score, SOS, moderazione immagini e funzioni predittive;</li>
    <li>retention definitiva per segnalazioni, immagini, SOS, log e moderazione;</li>
    <li>DPA, SCC, localizzazione server e configurazioni regionali con tutti i provider;</li>
    <li>cookie banner effettivo, elenco cookie attivi e consensi;</li>
    <li>età minima, consenso genitoriale e policy minori;</li>
    <li>ruoli privacy di partner commerciali, enti pubblici, comuni e operatori console.</li>
  </ul>
</LegalLayout>
