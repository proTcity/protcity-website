{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "protcity-website",
  "compatibility_date": "2026-05-01",
  "routes": [
    {
      "pattern": "www.protcity.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "html_handling": "drop-trailing-slash",
    "not_found_handling": "404-page"
  }
}
